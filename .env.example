# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Application (client) ID from the same portal
DISCORD_CLIENT_ID=

# Your Discord server (guild) ID — enable Developer Mode ? right-click server ? Copy Server ID
DISCORD_GUILD_ID=

# Channel IDs (right-click channel ? Copy Channel ID)
CHANNEL_LIVE_LOBBIES=
CHANNEL_LEADERBOARD=
CHANNEL_QUEUE_NIGHTS=

# Optional: role to ping for queue nights (right-click role ? Copy Role ID)
QUEUE_PING_ROLE_ID=

# Optional Deadlock API key (Bearer). Public endpoints often work without one.
DEADLOCK_API_KEY=

# Poll intervals (milliseconds)
LOBBY_POLL_MS=15000
LEADERBOARD_POLL_MS=300000
QUEUE_CHECK_MS=60000

# Default Asia queue server label shown in notifications
DEFAULT_SERVER_LABEL=Asia Super Server
